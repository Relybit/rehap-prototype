{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "textdomain": "colorful",
  "name": "colorful-blocks/divider",
  "title": "Divider",
  "description": "cover block divider.",
  "category": "colorful-blocks",
  "attributes": {
    "topDividerType": {
      "type": "string",
      "default": "tilt"
    },
    "topDividerLevel": {
      "type": "number",
      "default": 0
    },
    "topDividerColor": {
      "type": "string",
      "default": "#fff"
    },
    "topDividerVerticalPosition": {
      "type": "number",
      "default": 0
    },
    "topDividerOverlay": {
      "type": "boolean",
      "default": true
    },
    "bottomDividerType": {
      "type": "string",
      "default": "tilt"
    },
    "bottomDividerLevel": {
      "type": "number",
      "default": 0
    },
    "bottomDividerColor": {
      "type": "string",
      "default": "#fff"
    },
    "bottomDividerVerticalPosition": {
      "type": "number",
      "default": 0
    },
    "bottomDividerOverlay": {
      "type": "boolean",
      "default": true
    }
  },
  "style": "colorful-blocks/divider",
  "editorScript": "file:./index.js"
}